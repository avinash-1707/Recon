# HTTP + socket.io port
PORT=8787

# Web origin allowed by CORS (the Next app)
CLIENT_ORIGIN=http://localhost:3000

# Optional. When unset, the relay still runs — it just skips persistence
# (rooms/matches/stats live only in memory) AND disables auth. Set to your Neon
# pooled URL to enable both.
DATABASE_URL=

# Required for auth (only used when DATABASE_URL is set). Min 32 chars.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of THIS server (used by Better Auth for callbacks/cookies).
BETTER_AUTH_URL=http://localhost:8787
